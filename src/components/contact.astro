---
// 联系方式区块 —— 局部组件，统一使用全局 CSS 变量与赛博青蓝主色
const contacts = [
  {
    title: "电子邮箱",
    value: "cw@mrcw.top",
    hint: "扫码发送邮件",
    qr: "https://bu.dusays.com/2025/08/07/68946ad8a7b15.webp",
    alt: "邮箱二维码",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--sec)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  },
  {
    title: "QQ 群",
    value: "155014823",
    hint: "扫码加入 QQ 群",
    qr: "https://bu.dusays.com/2026/07/04/6a48d4119c3eb.webp",
    alt: "QQ 二维码",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--sec)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>`,
  },
];
---

<section id="contact" class="py-16 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-3 mb-2">
        <span class="h-px w-12 bg-gradient-to-r from-transparent to-[var(--sec)] opacity-40"></span>
        <span class="text-[var(--sec)] font-mono text-sm tracking-widest">联系我们</span>
        <span class="h-px w-12 bg-gradient-to-l from-transparent to-[var(--sec)] opacity-40"></span>
      </div>
      <h2 class="text-[var(--white)] text-4xl md:text-6xl font-bold mb-4 tracking-tight">CONTACT</h2>
      <p class="text-[var(--white-icon)] max-w-2xl mx-auto mt-2">
        有问题、有想法，或者想加入 iMakeit 机器人社 —— 发邮件或扫码进 QQ 群都行。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-2xl mx-auto">
      {
        contacts.map((c) => (
          <div class="qr-card group p-6 flex flex-col items-center text-center">
            <div class="contact-icon w-14 h-14 rounded-full flex items-center justify-center mb-4">
              <span set:html={c.icon} />
            </div>
            <h4 class="text-xl font-medium text-[var(--white)] mb-1">{c.title}</h4>
            <p class="text-[var(--sec)] font-mono mb-4">{c.value}</p>
            <div class="bg-white p-2 rounded-lg mb-3 transition-transform group-hover:scale-105">
              <img src={c.qr} alt={c.alt} class="w-32 h-32 rounded-lg" loading="lazy" />
            </div>
            <p class="text-sm text-[var(--white-icon)]">{c.hint}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  .shiny-sec {
    background: linear-gradient(135deg, #00e5ff 25%, #b8f7ff 50%, #00e5ff 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }

  @keyframes shine {
    0% { background-position: 100% 50%; }
    30%, 70% { background-position: 0% 50%; }
  }

  .qr-card {
    background: #0b111980;
    border: 1px solid var(--white-icon-tr);
    border-radius: 16px;
    transition: all 0.3s ease;
  }

  .qr-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px -8px rgba(0, 229, 255, 0.25);
    border-color: rgba(0, 229, 255, 0.4);
  }

  .contact-icon {
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.3);
  }
</style>
