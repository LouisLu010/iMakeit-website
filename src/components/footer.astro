---
const techStack = [
  { desc: "Built with", name: "Astro", icon: "/svg/astro.svg", alt: "Astro Logo" },
  { desc: "Styled with", name: "TailwindCSS", icon: "/svg/tailwindcss.svg", alt: "TailwindCSS Logo" },
];
---

<footer class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <!-- 社团标语 -->
    <div class="flex justify-center mb-10">
      <p class="text-center text-[var(--white)] text-lg md:text-xl font-medium">
        把想法 <span class="text-[var(--sec)]">造</span> 出来。
      </p>
    </div>

    <!-- 技术栈 -->
    <div class="flex justify-center">
      <div class="grid grid-cols-1 gap-3 w-full max-w-xs py-2">
        {
          techStack.map((tech) => (
            <div class="flex items-center justify-center space-x-3">
              <span class="text-[var(--white-icon)] text-sm">{tech.desc}</span>
              <img
                src={tech.icon}
                alt={tech.alt}
                class="h-5 w-5 object-contain brightness-0 invert opacity-50"
                loading="lazy"
              />
              <span class="text-[var(--white-icon)] text-sm">{tech.name}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-[#ffffff10]">
      <p class="text-center text-sm text-[var(--white-icon)]">
        <span class="block sm:inline">
          Copyright © 2015 - 2026
          <a href="https://www.imakeit.cn/" class="hover:text-[var(--sec)] transition-colors">iMakeit 机器人社</a>
          · 无锡一中. All rights reserved.
        </span>
      </p>
    </div>
  </div>
</footer>
